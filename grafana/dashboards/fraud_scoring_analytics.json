          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH last_1000 AS (\n  SELECT\n    cat_id,\n    fraud_flag,\n    created_at\n  FROM scores\n  WHERE $__timeFilter(created_at)\n    AND us_state IN (${us_state:sqlstring})\n    AND merch IN (${merch:sqlstring})\n    AND cat_id IS NOT NULL\n    AND cat_id <> ''\n    AND cat_id <> 'unknown'\n  ORDER BY created_at DESC\n  LIMIT 1000\n)\nSELECT\n  cat_id,\n  AVG(fraud_flag::float) * 100 AS fraud_share_percent,\n  COUNT(*) AS transactions_count,\n  SUM(fraud_flag) AS fraud_count\nFROM last_1000\nGROUP BY cat_id\nORDER BY fraud_share_percent DESC, transactions_count DESC;;",
          "refId": "A",
